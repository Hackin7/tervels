---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import PostCard from '../../../../components/PostCard.astro';
import CountryFlag from '../../../../components/CountryFlag.astro';
import { navigablePosts, postsByTrip, isLocationResolved } from '../../../../lib/aggregates';

export async function getStaticPaths() {
  const posts = navigablePosts(await getCollection('posts'));
  return postsByTrip(posts).map(t => ({
    params: { year: t.year, slug: t.trip },
    props: { trip: t },
  }));
}

const { trip } = Astro.props;
const base = import.meta.env.BASE_URL;

function fmtDateRange(start: Date, end: Date): string {
  const s = start.toISOString().slice(0, 10);
  const e = end.toISOString().slice(0, 10);
  return s === e ? s : `${s} – ${e}`;
}

const sortedPosts = [...trip.posts].sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
const resolvedCountries = trip.countries.filter((c: string) => c !== 'xx' && c !== 'unknown');
const resolvedCities = trip.cities.filter((c: string) => c !== 'Unknown');
const unresolvedCount = trip.posts.filter((p: any) => !isLocationResolved(p)).length;
---
<BaseLayout title={`${trip.displayName} ${trip.year} · tervels`}>
  <p class="muted"><a href={`${base}/trips`}>← all trips</a></p>
  <h1>{trip.displayName}</h1>
  <p class="muted">
    {trip.year} · {fmtDateRange(trip.earliest, trip.latest)} · {trip.posts.length} post{trip.posts.length === 1 ? '' : 's'}
    {unresolvedCount > 0 && ` · ${unresolvedCount} need triage`}
  </p>
  {(resolvedCountries.length > 0 || resolvedCities.length > 0) && (
    <div style="display:flex; gap:0.5rem; flex-wrap:wrap; margin:0.75rem 0 1.5rem;">
      {resolvedCountries.map((c: string) => <CountryFlag code={c} showName />)}
      {resolvedCities.map((c: string) => (
        <span style="background:#f0f0f0; padding:0.15rem 0.5rem; border-radius:999px; font-size:0.85rem;">{c}</span>
      ))}
    </div>
  )}
  <div class="grid grid-cards">
    {sortedPosts.map((p: any) => <PostCard post={p} />)}
  </div>
</BaseLayout>
