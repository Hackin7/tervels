---
import type { Post } from '../lib/aggregates';
import { postUrlSlug, isLocationResolved } from '../lib/aggregates';
import CountryFlag from './CountryFlag.astro';
import { Image } from 'astro:assets';
interface Props { post: Post; }
const { post } = Astro.props;
const base = import.meta.env.BASE_URL;
const href = `${base}/posts/${postUrlSlug(post)}`;
const dateStr = post.data.date.toISOString().slice(0, 10);
const resolved = isLocationResolved(post);
---
<a href={href} class="card" style="display:block; color:inherit; text-decoration:none;">
  {post.data.cover && (
    <Image src={post.data.cover} alt={post.data.title} width={520} height={320} style="border-radius:6px; margin-bottom:0.75rem;" />
  )}
  <h3>
    {post.data.title}
    {!resolved && (
      <span style="background:#fde68a; color:#92400e; font-size:0.65rem; padding:0.1rem 0.4rem; border-radius:999px; margin-left:0.4rem; vertical-align:middle; font-weight:normal;">
        needs triage
      </span>
    )}
  </h3>
  <p class="muted" style="margin:0;">
    {resolved ? (
      <><CountryFlag code={post.data.location.country} /> {post.data.location.city} · {dateStr}</>
    ) : (
      <>{dateStr}</>
    )}
  </p>
</a>
