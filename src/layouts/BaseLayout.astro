---
import '../styles/global.css';
interface Props { title?: string; description?: string; }
const { title = 'tervels', description = 'A travel log.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <nav class="site-nav">
      <a href={base || '/'}>tervels</a>
      <a href={`${base}/map`}>map</a>
      <a href={`${base}/places`}>places</a>
      <a href={`${base}/trips`}>trips</a>
      <a href={`${base}/events`}>events</a>
      <a href={`${base}/triage`}>triage</a>
    </nav>
    <main class="container">
      <slot />
    </main>
  </body>
</html>
