---
import '../styles/global.css';
interface Props { title?: string; description?: string; }
const { title = 'tervels', description = 'A travel log.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <nav class="site-nav">
      <a class="site-brand nav-link" href={base || '/'}>
        <svg aria-hidden="true" viewBox="0 0 24 24">
          <path d="M3 10.5 12 3l9 7.5" />
          <path d="M5 10v10h14V10" />
          <path d="M9 20v-6h6v6" />
        </svg>
        <span>tervels</span>
      </a>
      <div class="nav-links" aria-label="Primary navigation">
        <a class="nav-link" href={`${base}/map`}>
          <svg aria-hidden="true" viewBox="0 0 24 24">
            <path d="M9 18 3 21V6l6-3 6 3 6-3v15l-6 3-6-3Z" />
            <path d="M9 3v15" />
            <path d="M15 6v15" />
          </svg>
          <span>map</span>
        </a>
        <a class="nav-link" href={`${base}/places`}>
          <svg aria-hidden="true" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="9" />
            <path d="M3 12h18" />
            <path d="M12 3c2.3 2.5 3.5 5.5 3.5 9S14.3 18.5 12 21" />
            <path d="M12 3c-2.3 2.5-3.5 5.5-3.5 9S9.7 18.5 12 21" />
          </svg>
          <span>places</span>
        </a>
        <a class="nav-link" href={`${base}/trips`}>
          <svg aria-hidden="true" viewBox="0 0 24 24">
            <path d="M6 19c3 0 3-14 6-14s3 14 6 14" />
            <circle cx="6" cy="19" r="2" />
            <circle cx="12" cy="5" r="2" />
            <circle cx="18" cy="19" r="2" />
          </svg>
          <span>trips</span>
        </a>
        <a class="nav-link" href={`${base}/events`}>
          <svg aria-hidden="true" viewBox="0 0 24 24">
            <rect x="4" y="5" width="16" height="15" rx="2" />
            <path d="M8 3v4" />
            <path d="M16 3v4" />
            <path d="M4 10h16" />
          </svg>
          <span>events</span>
        </a>
      </div>
      <details class="nav-menu">
        <summary aria-label="Open navigation menu">
          <svg aria-hidden="true" viewBox="0 0 24 24">
            <path d="M4 7h16" />
            <path d="M4 12h16" />
            <path d="M4 17h16" />
          </svg>
          <span>menu</span>
        </summary>
        <div class="nav-menu-panel">
          <a class="nav-link" href={`${base}/map`}>
            <svg aria-hidden="true" viewBox="0 0 24 24">
              <path d="M9 18 3 21V6l6-3 6 3 6-3v15l-6 3-6-3Z" />
              <path d="M9 3v15" />
              <path d="M15 6v15" />
            </svg>
            <span>map</span>
          </a>
          <a class="nav-link" href={`${base}/places`}>
            <svg aria-hidden="true" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="9" />
              <path d="M3 12h18" />
              <path d="M12 3c2.3 2.5 3.5 5.5 3.5 9S14.3 18.5 12 21" />
              <path d="M12 3c-2.3 2.5-3.5 5.5-3.5 9S9.7 18.5 12 21" />
            </svg>
            <span>places</span>
          </a>
          <a class="nav-link" href={`${base}/trips`}>
            <svg aria-hidden="true" viewBox="0 0 24 24">
              <path d="M6 19c3 0 3-14 6-14s3 14 6 14" />
              <circle cx="6" cy="19" r="2" />
              <circle cx="12" cy="5" r="2" />
              <circle cx="18" cy="19" r="2" />
            </svg>
            <span>trips</span>
          </a>
          <a class="nav-link" href={`${base}/events`}>
            <svg aria-hidden="true" viewBox="0 0 24 24">
              <rect x="4" y="5" width="16" height="15" rx="2" />
              <path d="M8 3v4" />
              <path d="M16 3v4" />
              <path d="M4 10h16" />
            </svg>
            <span>events</span>
          </a>
        </div>
      </details>
    </nav>
    <main class="container">
      <slot />
    </main>
  </body>
</html>
